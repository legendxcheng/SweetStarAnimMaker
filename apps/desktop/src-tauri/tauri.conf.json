{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "SweetStarAnimMaker",
  "version": "0.1.0",
  "identifier": "com.sweetstar.animaker",
  "build": {
    "beforeBuildCommand": "corepack pnpm --dir ../.. desktop:prepare",
    "beforeDevCommand": "corepack pnpm --dir ../.. dev:studio",
    "devUrl": "http://127.0.0.1:14273",
    "frontendDist": "../../studio/dist"
  },
  "app": {
    "windows": [
      {
        "title": "SweetStarAnimMaker",
        "width": 1280,
        "height": 860,
        "minWidth": 1024,
        "minHeight": 720
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "targets": ["nsis"],
    "resources": {
      "../../../desktop-runtime": "desktop-runtime"
    }
  }
}
